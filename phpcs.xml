<?xml version="1.0"?>
<ruleset name="Popsi Cart Drawer">
    <description>WordPress coding standards for Popsi Cart Drawer plugin</description>
    
    <!-- Include the WordPress coding standards -->
    <rule ref="WordPress">
        <exclude name="WordPress.Files.FileName.InvalidClassFileName" />
        <exclude name="WordPress.Files.FileName.NotHyphenated" />
    </rule>
    
    <!-- Include WordPress Extra standards -->
    <rule ref="WordPress-Extra" />
    
    <!-- Include WordPress Docs standards -->
    <rule ref="WordPress-Docs" />
    
    <!-- Files and directories to check -->
    <file>.</file>
    
    <!-- Exclude directories -->
    <exclude-pattern>vendor/</exclude-pattern>
    <exclude-pattern>node_modules/</exclude-pattern>
    <exclude-pattern>.git/</exclude-pattern>
    <exclude-pattern>assets/</exclude-pattern>
    <exclude-pattern>export/</exclude-pattern>
    
    <!-- Only check PHP files -->
    <arg name="extensions" value="php" />
    
    <!-- Show progress and sniff names -->
    <arg value="ps" />
    
    <!-- Set severity to 5 (errors only) by default, can be overridden -->
    <arg name="severity" value="5" />
    
    <!-- Set tab width -->
    <arg name="tab-width" value="4" />
</ruleset>
